<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDFCF4"
    tools:context=".MainActivity">

    <!-- Container to host dynamic WebView instances support Multi-Tabs -->
    <FrameLayout
        android:id="@+id/webViewContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <!-- Overlay glassmorphic view for feedback indicator (Swipe next link animation helper) -->
    <TextView
        android:id="@+id/queueSwipeIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_swipe_indicator"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:textColor="#386B20"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:elevation="6dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Beautiful, Floating Glassmorphic Bottom Control Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomBarCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="#E1E3D3"
        app:cardBackgroundColor="#FDFCF4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Integrated Horizontal Progress Bar at the very top edge -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="@android:style/Widget.DeviceDefault.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#386B20"
                android:progressBackgroundTint="@android:color/transparent" />

            <!-- Command items with URL input -->
            <LinearLayout
                android:id="@+id/bottomControlBar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <!-- Navigation Controls -->
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_back"
                    android:contentDescription="Go Back"
                    app:tint="#43483E" />

                <ImageButton
                    android:id="@+id/btnForward"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_forward"
                    android:contentDescription="Go Forward"
                    app:tint="#43483E" />

                <!-- Input Field: Search/URL bar -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_url_input">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <ImageView
                            android:id="@+id/webStatusIcon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_globe"
                            app:tint="#5D624E"
                            android:layout_marginEnd="6dp" />

                        <EditText
                            android:id="@+id/etSearchUrl"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="Search or enter URL"
                            android:textColorHint="#5D624E"
                            android:textColor="#1A1C19"
                            android:textSize="13sp"
                            android:imeOptions="actionGo"
                            android:singleLine="true"
                            android:inputType="textUri"
                            android:padding="0dp" />

                        <ImageButton
                            android:id="@+id/btnClearUrl"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_clear"
                            android:visibility="gone"
                            app:tint="#5D624E"
                            android:contentDescription="Clear URL Input" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Queue Dock Counter Option -->
                <FrameLayout
                    android:id="@+id/queueDockButton"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/queueIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_queue_list"
                            app:tint="#43483E" />

                        <!-- Active Queue Accent Item Count Indicator -->
                        <FrameLayout
                            android:id="@+id/queueBadgeContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="1dp"
                            android:visibility="invisible">

                            <TextView
                                android:id="@+id/queueBadgeText"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:background="@drawable/bg_badge"
                                android:textColor="#FFFFFF"
                                android:textSize="8sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:text="0" />
                        </FrameLayout>
                    </LinearLayout>
                </FrameLayout>

                <!-- Multi-Tab Switcher Overview button -->
                <FrameLayout
                    android:id="@+id/btnTabs"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/tabsIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_tabs"
                            app:tint="#43483E" />

                        <!-- Active Tab Count Indicator badge -->
                        <FrameLayout
                            android:id="@+id/tabsBadgeContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="1dp"
                            android:visibility="visible">

                            <TextView
                                android:id="@+id/tabsBadgeText"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:background="@drawable/bg_badge"
                                android:textColor="#FFFFFF"
                                android:textSize="8sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:text="1" />
                        </FrameLayout>
                    </LinearLayout>
                </FrameLayout>

                <ImageButton
                    android:id="@+id/btnRefresh"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_refresh"
                    android:contentDescription="Reload Page"
                    app:tint="#43483E" />

            </LinearLayout>

            <!-- Thin accent micro-line to show queue presence when items are listed -->
            <View
                android:id="@+id/queueAccentLine"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#386B20"
                android:visibility="gone" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Full-screen Tab Overview Screen overlay -->
    <LinearLayout
        android:id="@+id/tabOverviewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FDFCF4"
        android:elevation="20dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <!-- Tab Header matching Natural Tones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="16dp"
            android:background="#EFF1E0">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTabOverviewHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tabs Overview"
                    android:textColor="#1A1C19"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTabOverviewSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 active tab"
                    android:textColor="#5D624E"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNewTab"
                style="@style/Widget.Material3.Button.IconButton.Filled"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:icon="@drawable/ic_add"
                app:iconTint="#FFFFFF"
                app:backgroundTint="#386B20"
                android:contentDescription="Open New Tab" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabOverviewClose"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Done"
                android:textColor="#386B20"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Divider line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E1E3D3" />

        <!-- Tab cards list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTabs"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp"
            android:clipToPadding="false" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
